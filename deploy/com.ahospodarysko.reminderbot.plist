<?xml version="1.0" encoding="UTF-8"?>
<!--
  launchd agent template for the Telegram reminder bot (macOS).

  This is a TEMPLATE: replace every __USER__ with the account name on the target
  machine (the output of `whoami`), then install it as described in deploy/README.md.
  The path assumes the repo lives at /Users/__USER__/telegram_reminder_bot — adjust
  all three paths if you cloned it elsewhere.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ahospodarysko.reminderbot</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/__USER__/telegram_reminder_bot/run.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/__USER__/telegram_reminder_bot</string>

    <!-- Start at login/boot and keep it alive (restart if it ever exits). -->
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <!-- Don't hammer Telegram if it crash-loops: wait 10s between restarts. -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <!-- All stdout/stderr (the bot's logs) go here. -->
    <key>StandardOutPath</key>
    <string>/Users/__USER__/telegram_reminder_bot/logs/bot.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/__USER__/telegram_reminder_bot/logs/bot.log</string>
</dict>
</plist>
