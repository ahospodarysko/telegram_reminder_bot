# Copy to .env and fill in. NEVER commit the real .env.
#
# Bot tokens issued by BotFather (https://t.me/BotFather). Full-access credentials —
# treat them like passwords. Read only from the environment at runtime.
# Production bot — used by default.
BOT_TOKEN=
# Test bot — used when BOT_ENV=test (see below). Needed only for development.
TEST_BOT_TOKEN=

# Optional. Selects which bot to run. Set to "test" (or "dev") to use TEST_BOT_TOKEN
# and a separate database; anything else (including unset) runs the production bot.
# Example dev run:  BOT_ENV=test ./run.sh
# BOT_ENV=test

# Optional. IANA timezone assigned to new users on first /start (changeable per user
# with /timezone). If unset, the bot uses the host machine's timezone, then UTC.
# DEFAULT_TZ=Europe/Kyiv

# Optional. SQLite database file path. Overrides the default, which is reminders.db
# in production and reminders.test.db when BOT_ENV=test.
# DB_PATH=reminders.db
