# Copy to .env and fill in. NEVER commit the real .env.
#
# Bot token issued by BotFather (https://t.me/BotFather). Full-access credential —
# treat it like a password. Read only from the environment at runtime.
BOT_TOKEN=

# Optional. IANA timezone assigned to new users on first /start (changeable per user
# with /timezone). If unset, the bot uses the host machine's timezone, then UTC.
# DEFAULT_TZ=Europe/Kyiv

# Optional. SQLite database file path. Defaults to reminders.db in the project root.
# DB_PATH=reminders.db
